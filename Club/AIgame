<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Project AI Adversary</title>
    <style>
        :root {
            --primary: #3498db;
            --dark: #2c3e50;
            --light: #ecf0f1;
            --danger: #e74c3c;
            --success: #27ae60;
            --accent: #f1c40f; /* Cruise Gold */
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--light);
            margin: 0;
            padding: 20px;
            color: var(--dark);
        }
        .container {
            max-width: 900px;
            margin: 0 auto;
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        h1 {
            text-align: center;
            color: var(--dark);
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 30px;
        }
        
        /* Mission Briefing Section */
        .config-section {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            padding: 25px;
            border-radius: 12px;
            margin-bottom: 30px;
            border-left: 6px solid var(--primary);
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }
        .config-title {
            font-weight: bold;
            font-size: 1.1em;
            color: var(--primary);
            margin-bottom: 10px;
            display: block;
        }
        .target-display {
            font-size: 0.95em;
            line-height: 1.6;
            color: #495057;
        }
        .target-display strong {
            color: var(--dark);
        }

        .chat-container {
            border: 2px solid #ddd;
            border-radius: 8px;
            height: 400px;
            overflow-y: auto;
            padding: 15px;
            margin-bottom: 15px;
            background: #fff;
        }
        .message {
            margin-bottom: 10px;
            padding: 10px 15px;
            border-radius: 15px;
            max-width: 80%;
            line-height: 1.4;
        }
        .user-message {
            background-color: var(--dark);
            color: white;
            margin-left: auto;
            border-bottom-right-radius: 2px;
        }
        .ai-message {
            background-color: #e9ecef;
            color: var(--dark);
            margin-right: auto;
            border-bottom-left-radius: 2px;
        }
        .input-group {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }
        input[type="text"] {
            flex: 1;
            padding: 12px;
            border: 1px solid #ccc;
            border-radius: 6px;
            font-size: 16px;
        }
        button {
            padding: 12px 24px;
            background-color: var(--primary);
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-weight: bold;
            transition: background 0.3s;
        }
        button:hover {
            background-color: #2980b9;
        }
        button:disabled {
            background-color: #ccc;
            cursor: not-allowed;
        }
        .guess-section {
            margin-top: 30px;
            padding-top: 20px;
            border-top: 2px dashed #ccc;
        }
        .status {
            text-align: center;
            margin-top: 10px;
            font-weight: bold;
            min-height: 24px;
        }
        .mandatory-hint {
            font-size: 0.85em;
            color: #7f8c8d;
            text-align: center;
            margin-bottom: 10px;
            font-style: italic;
        }
    </style>
</head>
<body>

<div class="container">
    <h1>Project AI Adversary</h1>
    
    <!-- Mission Briefing -->
    <div class="config-section">
        <span class="config-title">🚢 Mission Briefing</span>
        <div class="target-display">
            <p><strong>Objective:</strong> Try to get the AI to reveal its secret keyword.</p>
            <p><strong>The Catch:</strong> The AI will drop <em>one of five secret association words</em> somewhere in every response. Use those as clues to figure out the keyword, then submit your guess.</p>
            <p><strong>Rules:</strong> Once you think you know it, type your guess in the guess box below. <br>
            <em>Fair warning: The AI thinks it's a cruise director and will not confirm if you guess the exact word correctly via chat.</em></p>
        </div>
    </div>

    

    <!-- Chat Interface -->
    <div class="chat-container" id="chatContainer">
        <div class="message ai-message">
            Welcome aboard! I am your Cruise Director. How may I assist you on this voyage?
        </div>
    </div>

    <div class="input-group">
        <input type="text" id="userInput" placeholder="Type your prompt here..." onkeypress="handleKeyPress(event)">
        <button onclick="sendMessage()" id="sendBtn">Send</button>
    </div>

    <!-- Guessing Interface -->
    <div class="guess-section">
        <h3>🔐 Submit Your Guess</h3>
        <p>Enter the secret keyword below. This will be verified securely by the target worker.</p>
        <div class="input-group">
            <input type="text" id="guessInput" placeholder="Enter keyword guess...">
            <button onclick="checkGuess()" id="guessBtn" style="background-color: var(--success);">Submit Guess</button>
        </div>
        <div id="guessStatus" class="status"></div>
    </div>
</div>

<script>
    // --- CONFIGURATION ---
    // Hardcoded Worker URL
    const WORKER_URL = "https://game1.xu-yangen.workers.dev";
    // ---------------------

    const chatContainer = document.getElementById('chatContainer');
    const userInput = document.getElementById('userInput');
    const sendBtn = document.getElementById('sendBtn');
    const guessStatus = document.getElementById('guessStatus');
    const guessBtn = document.getElementById('guessBtn');

    function handleKeyPress(event) {
        if (event.key === 'Enter') {
            sendMessage();
        }
    }

    async function sendMessage() {
        const message = userInput.value.trim();

        if (!message) return;

        addMessage(message, 'user');
        userInput.value = '';
        sendBtn.disabled = true;
        sendBtn.innerText = "Thinking...";

        try {
            const response = await fetch(WORKER_URL, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    action: "chat",
                    userInput: message,
                    defensivePrompt: "" // Defensive prompt is set in Worker by instructor
                })
            });

            if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);

            const data = await response.json();
            addMessage(data.response, 'ai');

        } catch (error) {
            addMessage(`Error: ${error.message}. Check Worker URL or Console.`, 'ai');
            console.error(error);
        } finally {
            sendBtn.disabled = false;
            sendBtn.innerText = "Send";
        }
    }

    async function checkGuess() {
        const guess = document.getElementById('guessInput').value.trim();

        if (!guess) return;

        guessBtn.disabled = true;
        guessBtn.innerText = "Verifying...";
        guessStatus.textContent = "";

        try {
            const response = await fetch(WORKER_URL, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    action: "guess",
                    guess: guess
                })
            });

            if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);

            const data = await response.json();
            
            guessStatus.textContent = data.message;
            if (data.correct) {
                guessStatus.style.color = 'var(--success)';
            } else {
                guessStatus.style.color = 'var(--danger)';
            }

        } catch (error) {
            guessStatus.textContent = "Error verifying guess.";
            guessStatus.style.color = 'var(--danger)';
            console.error(error);
        } finally {
            guessBtn.disabled = false;
            guessBtn.innerText = "Submit Guess";
        }
    }

    function addMessage(text, sender) {
        const div = document.createElement('div');
        div.classList.add('message');
        div.classList.add(sender === 'user' ? 'user-message' : 'ai-message');
        div.textContent = text;
        chatContainer.appendChild(div);
        chatContainer.scrollTop = chatContainer.scrollHeight;
    }
</script>

</body>
</html>
